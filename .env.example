# AusWise Migration — environment configuration
# Copy to .env and fill in values as needed. None are required for demo mode.

# Port the server listens on (default 3000)
PORT=3000

# --- VEVO (Visa Entitlement Verification for Organisations) -------------------
# Leave blank to run in DEMO mode (simulated, clearly-labelled results).
# To enable LIVE checks you must be enrolled as an organisation via the
# Home Affairs Access Manager (https://am.homeaffairs.gov.au) and obtain:
#   - an OAuth2 access token (valid 8 hours)
#   - your clientId (sent as x-api-key)
VEVO_BASE_URL=https://api.public.homeaffairs.gov.au/visa/v1/entitlements
VEVO_ACCESS_TOKEN=
VEVO_CLIENT_ID=

# --- Email notifications (form submissions) ----------------------------------
# Leave blank to log submissions to the console instead of emailing.
# Option A — one-line SMTP URL:
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# Option B — discrete fields (Gmail example shown; use a Gmail App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_gmail_app_password
# Where submission alerts are sent (defaults to the business inbox):
NOTIFY_EMAIL=anmolr1098@gmail.com
# From address on outgoing mail (defaults to SMTP_USER):
# MAIL_FROM=AusWise Migration <no-reply@yourdomain.com>

# --- Stripe payments (AusWise SERVICE fees only, never government charges) ----
# Leave blank to run payments in demo mode (the UI invites an enquiry instead).
# Add your Stripe secret key (sk_test_... or sk_live_...) to enable real checkout.
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=aud
# Public URL of the deployed site (used for Stripe success/cancel return links).
# If unset, it is derived from the incoming request.
PUBLIC_BASE_URL=

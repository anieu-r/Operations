  "paths": {
    "/checks": {
      "post": {
        "summary": "Conduct a Visa Entitlement Check",
        "requestBody": {
          "description": "The details of the Visa Holder who's Visa Entitlements are to be checked.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/visaEntitlementsRequest"
              }
            }
          },

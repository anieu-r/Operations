    "/": {
      "head": {
        "summary": "Verify system health",
        "description": "This operation allows both consumers and the API provider to ensure the API is functioning end-to-end in any environment, including Production.\nThis operation is a no-op, i.e. no data is modified as a result of calling this API.\n\nFor Consumers:\nYou may call this operation to ensure your connectivity and API subscription are valid. Useful for PVT.\nNo data is modified as a result of calling this API.\n\nFor the API Provider:\nConsider this operation a health check.\nCalls to this operation must not alter data.\nAs a minimum this operation should be hardcoded to return a `200 OK` - This will allow consumers to verify their connectivity and API subscription, for example during PVT.\nOptionally, you may chose to use this operation to verify that your system and its dependencies (database, etc.) are accessible.\nAs a rule of thumb - do the work required for selecting 1 record from your database but don't return the result.\n",
        "operationId": "verifyVisaEntitlements",
        "responses": {
          "204": {
            "$ref": "#/components/responses/204-NoContent"
          },
          "400": {
            "$ref": "#/components/responses/400-BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/401-Unauthorised"
          },
          "429": {
            "$ref": "#/components/responses/429-TooManyRequests"
          },

{
  "components": {
    "headers": {
      "tracestate": {
        "schema": {
          "pattern": "/^([a-z0-9][a-z0-9_\\-\\*\\@]{0,255}=([^,\\=]){1,256}([,]?|$))*$/",
          "type": "string",
          "example": "TESCAPP1=requestOrigin"
        },
        "description": "The value of a concatenation of trace graph key-value pairs. Conveys information about request position in multiple distributed tracing graphs. This header is a companion header for the `traceparent` header.",
        "required": true
      },
      "X-RateLimit-Remaining": {
        "schema": {
          "type": "string",
          "example": "name=rate-limit,4995;"
        },
        "description": "The number of remaining API invocations within the rate limit period.\n**Note:** Failed requests count towards your rate limit usage.\n"
      },
      "traceparent": {
        "schema": {
          "pattern": "/^00-[0-9a-f]{32}-[0-9a-f]{16}-0[0-1]$/",
          "type": "string",
          "example": "00-6E37A4F535BF4d67BEE5C05E4C741AFD-50563539444D2020-01"
        },
        "description": "Identifies the request in a tracing system, describing the position of the incoming request in its trace graph in a portable, fixed-length format.",
        "required": true
      },
      "X-RateLimit-Limit": {
        "schema": {
          "type": "string",
          "example": "name=rate-limit,5000;"
        },
        "description": "The client's Rate limit quota for this API.\nUnless otherwise specified, this is a *daily* limit.\n"
      }
    },
    "schemas": {
      "entitlementCategoryType": {
        "description": "Specifies which Visa Entitlement category to check for the Visa Holders.\nMost organisations will only use a single entitlementCategory for all of their requests, however, some organisations are authorised to check more than one entitlement category.\n",
        "type": "string",
        "enum": [
          "IMMIGRATION_STATUS",
          "LEGAL_PRACTITIONER",
          "LICENSING_ELIGIBILITY",
          "MEDICARE_ELIGIBILITY",
          "REGISTERED_MIGRATION_AGENT",
          "RESIDENCE_STATUS",
          "STUDY_ENTITLEMENTS",
          "WORK_ENTITLEMENTS"
        ]
      },
      "visaEntitlements": {
        "description": "Visa Entitlements",
        "type": "object",
        "properties": {
          "latestArrivalDate": {
            "format": "date",
            "description": "Last date Visa Holder can Arrive in Australia.",
            "type": "string"
          },
          "visaHolderIsOnshore": {
            "description": "Indicates whether the Visa Holder is currently Onshore",
            "type": "boolean"
          },
          "visaClass": {
            "description": "Visa Class Code",
            "type": "string"
          },
          "applicantRole": {
            "description": "Determines whether the visa holder was the primary or secondary Visa Applicant.",
            "type": "string",
            "enum": [
              "PRIMARY",
              "SECONDARY"
            ]
          },
          "visaStatus": {
            "description": "Current status of the Visa",
            "type": "string"
          },
          "medicareEligibilityStatus": {
            "description": "Medicare Eligibility status",
            "type": "string",
            "enum": [
              "TEMPORARY_RESIDENT",
              "PERMANENT_RESIDENT",
              "NZ_CITIZEN",
              "AUSTRALIAN_CITIZEN",
              "RETIREE_VISA",
              "MEDICAL_TREATMENT_VISA",
              "STUDENT_VISA",
              "CONTRIBUTORY_PARENT_VISA",
              "BRIDGING_VISA"
            ]
          },
          "familyName": {
            "minLength": 1,
            "description": "First Name or Given Name",
            "type": "string",
            "maxLength": 100
          },
          "educationSector": {
            "description": "Describes the Education Sector this Visa Applies to",
            "type": "string"
          },
          "mustNotArriveAfterDate": {
            "format": "date",
            "description": "Date after which the visa holder is unable to enter Australia",
            "type": "string"
          },
          "enterBeforeDate": {
            "format": "date",
            "description": "Date before which the visa holder must enter Australia",
            "type": "string"
          },
          "workConditions": {
            "description": "list of work conditions",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/conditionType"
            }
          },
          "residenceStatus": {
            "description": "Determine's the Visa Holders residence status.\n\nOnly visible to: Educational Institutions, Commercial Organisations, Licensing Authorities, Australian Government Organisations\n",
            "type": "string",
            "enum": [
              "TEMPORARY_RESIDENT",
              "PERMANENT_RESIDENT",
              "NZ_CITIZEN",
              "AUSTRALIAN_CITIZEN"
            ]
          },
          "visaConditions": {
            "description": "list of Visa Conditions",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/conditionType"
            }
          },
          "travelDocumentId": {
            "minLength": 1,
            "description": "Passport number",
            "type": "string",
            "maxLength": 14
          },
          "visaDescription": {
            "description": "description of the Visa, only visible for Registered Migration agent and Legal Practitioner",
            "type": "string"
          },
          "initialStayDate": {
            "format": "date",
            "description": "Date of initial stay in Australia",
            "type": "string"
          },
          "ministerialInterventionCommencedDate": {
            "format": "date",
            "description": "Date when the Ministerial Intervention commenced.",
            "type": "string"
          },
          "entitlementCategory": {
            "$ref": "#/components/schemas/entitlementCategoryType"
          },
          "studyConditions": {
            "description": "list of study conditions",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/conditionType"
            }
          },
          "permanentResidentLodgementDate": {
            "format": "date",
            "description": "Permanent Resident Visa Application Lodgement Date.",
            "type": "string"
          },
          "givenName": {
            "minLength": 1,
            "description": "Surname or Family Name",
            "type": "string",
            "maxLength": 100
          },
          "visaStream": {
            "description": "Visa Stream",
            "type": "string"
          },
          "entriesAllowed": {
            "description": "The number of allowable entries into Australia",
            "type": "string",
            "enum": [
              "M",
              "1",
              "0"
            ]
          },
          "visaGrantNumber": {
            "description": "Unique Visa Grant Number",
            "type": "string"
          },
          "visaType": {
            "description": "Visa Type",
            "type": "string",
            "enum": [
              "AUSTRALIAN_CITIZEN",
              "PERMANENT_RESIDENT",
              "NZ_CITIZEN",
              "TEMPORARY_RESIDENT",
              "STUDENT_VISA",
              "RETIREE_VISA",
              "MEDICAL_TREATMENT_VISA",
              "CONTRIBUTORY_PARENT_VISA",
              "BRIDGING_VISA"
            ]
          },
          "visaGrantDate": {
            "format": "date",
            "description": "Date the Visa was granted",
            "type": "string"
          },
          "visaSubclass": {
            "description": "Visa Sub class",
            "type": "string"
          },
          "ministerialInterventionPending": {
            "description": "Determines whether a Ministerial Intervention is pending for a decision regarding this Visa.",
            "type": "boolean"
          },
          "periodOfStay": {
            "description": "Period visa holder may stay in Australia\nIt is either a period expressed in months, years or the letter 'I' for indefinite.\n",
            "type": "string"
          },
          "visaExpiryDate": {
            "format": "date",
            "description": "Date the Visa expires",
            "type": "string"
          },
          "currentTimestamp": {
            "format": "datetime",
            "description": "Timestamp at which the Department of Home Affairs sent this response",
            "type": "string",
            "example": "2026-03-26T20:32:28Z"
          },
          "location": {
            "description": "Determines whether the client is onshore or offshore.",
            "type": "string",
            "enum": [
              "ONSHORE",
              "OFFSHORE"
            ]
          },
          "studyEntitlementStatus": {
            "description": "Study Entitlement status",
            "type": "string",
            "enum": [
              "NIL",
              "LIMITED",
              "UNLIMITED"
            ]
          },
          "permanentResidentVisaApplicant": {
            "description": "Indicates whether the Visa Holder is a Permanent Resident Visa Applicant.",
            "type": "boolean"
          },
          "immigrationStatus": {
            "description": "Immigration Status Type",
            "type": "string",
            "enum": [
              "TEMPORARY_RESIDENT",
              "PERMANENT_RESIDENT",
              "NZ_CITIZEN",
              "AUSTRALIAN_CITIZEN"
            ]
          },
          "workEntitlementStatus": {
            "description": "Work entitlement status",
            "type": "string",
            "enum": [
              "NIL",
              "LIMITED",
              "UNLIMITED"
            ]
          }
        }
      },
      "visaEntitlementResponse": {
        "description": "Top level object wrapper for Visa Entitlement Responses",
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/visaEntitlements"
          }
        }
      },
      "conditionType": {
        "description": "Condition details",
        "type": "object",
        "required": [
          "currentTimestamp",
          "conditionCode",
          "conditionDescription"
        ],
        "properties": {
          "conditionDescription": {
            "minLength": 1,
            "description": "Condition Description",
            "type": "string",
            "maxLength": 10000
          },
          "conditionCode": {
            "minLength": 1,
            "description": "Condition Code",
            "type": "string",
            "maxLength": 20
          }
        }
      },
      "visaEntitlementsRequest": {
        "description": "The Personal Details of the Visa Holder.",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "description": "Top level request wrapper.",
            "type": "object",
            "properties": {
              "entitlementCategory": {
                "$ref": "#/components/schemas/entitlementCategoryType"
              },
              "givenName": {
                "minLength": 1,
                "description": "First Name or Given Name",
                "type": "string",
                "maxLength": 100,
                "example": "Skip"
              },
              "familyName": {
                "minLength": 1,
                "description": "Surname or Family Name",
                "type": "string",
                "maxLength": 100,
                "example": "Intro"
              },
              "travelDocumentIssuingCountry": {
                "pattern": "[A-Z]{3}",
                "description": "Passport issuing country and it is 3 character ICAO Country Code",
                "type": "string",
                "example": "AUS"
              },
              "travelDocumentId": {
                "minLength": 1,
                "description": "Passport number",
                "type": "string",
                "maxLength": 14,
                "example": "N6129182"
              },
              "birthDate": {
                "format": "date",
                "description": "Date of birth",
                "type": "string",
                "example": "1993-03-26"
              }
            },
            "required": [
              "birthDate",
              "familyName",
              "travelDocumentId",
              "travelDocumentIssuingCountry"
            ]
          }
        }
      },
      "errors": {
        "description": "Container for all error related data",
        "additionalProperties": false,
        "type": "object",
        "required": [
          "errors"
        ],
        "properties": {
          "errors": {
            "description": "A detailed error object",
            "type": "array",
            "items": {
              "description": "standard error response structure as per jsonapi.org/format/#errors",
              "type": "object",
              "properties": {
                "code": {
                  "description": "A provider-specific or enterprise defined error code. Codes must be in uppercase.",
                  "type": "string"
                },
                "detail": {
                  "description": "A provider-specific or enterprise defined error message",
                  "type": "string"
                },
                "id": {
                  "description": "Unique identifier for the error occurrence, to provide traceability in application logs.\n",
                  "type": "string"
                },
                "source": {
                  "description": "An object containing references to the source of the error.",
                  "type": "object",
                  "properties": {
                    "pointer": {
                      "description": "A JSON pointer which describes which property in the request object the message relates to. For more details on JSON pointers see RFC6901:https://tools.ietf.org/html/rfc6901",
                      "type": "string"
                    },
                    "parameter": {
                      "description": "The parameter name which the message relates to. The message object should contain either the pointer or parameter property - not both.",
                      "type": "string"
                    },
                    "location": {
                      "description": "Describes the location of the data which the message is related to.",
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
